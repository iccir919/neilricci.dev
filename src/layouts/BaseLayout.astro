---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Neil Ricci - Web Designer & Developer" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>👋</text></svg>" />

    <!-- Preconnect for Google Analytics -->
    <link rel="preconnect" href="https://www.googletagmanager.com" />

    <!-- Google Analytics -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-RTB4EGWXPD"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-RTB4EGWXPD');
    </script>
  </head>
  <body>
    <nav>
      <h1 class="logo"><a href="/">Neil Ricci</a></h1>
    <ul class="nav-links">
        <li><a class="nav-link" href="/projects">Projects</a></li>
        <li><a class="nav-link" href="/blog">Blog</a></li>
        <li><a class="nav-link" href="/photos">Photos</a></li>
        <li><a class="nav-link" href="/contact">Contact</a></li>
    </ul>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      <ul class="social-links">
        <li>
          <a href="https://www.linkedin.com/in/neil-ricci/" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
            <img class="social-icon" src="/assets/social-icons/linkedIn.svg" alt="LinkedIn" />
          </a>
        </li>
        <li>
          <a href="https://github.com/iccir919" aria-label="GitHub" target="_blank" rel="noopener noreferrer">
            <img class="social-icon" src="/assets/social-icons/github.svg" alt="GitHub" />
          </a>
        </li>
        <li>
          <a href="https://x.com/realNeilVR" aria-label="Twitter/X" target="_blank" rel="noopener noreferrer">
            <img class="social-icon" src="/assets/social-icons/twitter-x.svg" alt="Twitter/X" />
          </a>
        </li>
        <li>
          <a href="https://www.instagram.com/3rdeye919/" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
            <img class="social-icon" src="/assets/social-icons/instagram.svg" alt="Instagram" />
          </a>
        </li>
      </ul>
      <p>© 2025 Neil Ricci</p>
    </footer>
  </body>
</html>