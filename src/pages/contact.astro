---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Contact - Neil Ricci"
  description="Get in touch with Neil Ricci for web design and development projects."
>
  <section class="contact">
    <h2>Contact Me</h2>
    <form
      id="contact-form"
      action="https://formspree.io/f/xpwynzzd"
      method="POST"
    >
      <label for="name">Name</label>
      <input type="text" id="name" name="name" required />

      <label for="email">Email</label>
      <input type="email" id="email" name="email" required />

      <label for="message">Message</label>
      <textarea id="message" name="message" rows="5" required></textarea>

      <button type="submit">Send Message</button>
    </form>

    <div class="email">
      <p>Prefer to email me directly?</p>
      <a href="mailto:neil.ricci9@gmail.com" class="email-button">Email Me</a>
    </div>
  </section>
</BaseLayout>