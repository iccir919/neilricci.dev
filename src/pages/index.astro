---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/projects';

// Take the 3 most recent projects
const recentProjects = [...projects]
  .sort((a, b) => new Date(b.completion_date).getTime() - new Date(a.completion_date).getTime())
  .slice(0, 3);
---
<BaseLayout title="Neil Ricci - Web Designer & Developer">
  <section class="splash">
    <div class="splash-section bio">
      <h2>Hi 👋, I'm Neil</h2>
      <p>I design and build websites that are clean, accessible, and effortless to use. Based in Oakland, usually with a side project or two going. Outside of code, I'm usually cooking, taking photos, or out on a walk somewhere in the East Bay.</p>
    </div>
    <div class="splash-section image">
      <img src="/assets/neil_ricci.jpeg" alt="Neil Ricci smiling with the Golden Gate Bridge in the background" />
    </div>
  </section>

  <section class="recent-projects">
    <h2>Recent projects</h2>
    <div id="recent-projects-list">
      {recentProjects.map((project) => (
        <a class="recent-project" href={project.link || project.github_repo} target="_blank" rel="noopener noreferrer">
          <img src={project.imageUrl} alt={`Screenshot of ${project.name}`} />
          <h3>{project.name}</h3>
          <p>{project.description}</p>
        </a>
      ))}
    </div>
    <a href="/projects">View all projects →</a>
  </section>
</BaseLayout>